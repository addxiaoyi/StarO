# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/.playwright-cli/
# verification archive (auto-generated by tests)
verification-archive/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# temporary scripts (local development utilities)
*.local.js
*.local.ts

# code analysis
.codegraph/

# deployment scripts
baota-*.sh
deploy.sh
deploy.ps1

# build artifacts (auto-generated during deployment)
*.tar.gz
*.zip
deploy-package/
deploy-build.bat
startup-check.sh
update-*.sh
update-*.bat
check-server.sh
check-server.ps1

# playwright screenshots
.playwright-mcp-*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.lint-latest.log
.next-dev-*.log
*.log
.local/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
